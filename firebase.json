{
  "hosting": {
    "site": "kumtechgateway-237",
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase-debug.log",
      ".firebaserc",
      ".gitignore",
      ".hintrc",
      "**/.*",
      "**/node_modules/**",
      "package.json",
      "package-lock.json",
      "scripts/**"
    ],
    "rewrites": [
      {
        "source": "/blog/**",
        "destination": "/blog-post.html"
      }
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "africa-south1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
