rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isValidReviewSubmission() {
      return request.resource.data.keys().hasOnly([
        "name",
        "company",
        "rating",
        "review",
        "approved",
        "createdAt"
      ]) &&
      request.resource.data.name is string &&
      request.resource.data.name.size() >= 2 &&
      request.resource.data.name.size() <= 80 &&
      request.resource.data.company is string &&
      request.resource.data.company.size() <= 80 &&
      request.resource.data.review is string &&
      request.resource.data.review.size() >= 10 &&
      request.resource.data.review.size() <= 1000 &&
      request.resource.data.rating is int &&
      request.resource.data.rating >= 1 &&
      request.resource.data.rating <= 5 &&
      request.resource.data.approved == false &&
      request.resource.data.createdAt == request.time;
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.approved == true;
      allow create: if false;
      allow update, delete: if false;
    }

    // All other collections are locked down by default.
    // Add rules for other collections here if you have them.
  }
}
